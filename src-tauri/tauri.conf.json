{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qwen Prompt Builder",
  "version": "0.1.0",
  "identifier": "com.qpb.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Qwen Prompt Builder",
        "width": 1440,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; connect-src 'self' http://127.0.0.1:* https://api.anthropic.com https://huggingface.co https://github.com; img-src 'self' data: blob: asset:; style-src 'self' 'unsafe-inline'; script-src 'self';"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "resources": [
      "resources/models.json"
    ],
    "externalBin": [
      "bin/llama-server-x86_64-pc-windows-msvc"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://example.com/qpb-updates/{{target}}/{{current_version}}"
      ],
      "dialog": true
    }
  }
}
